REPOFORGE_DATABASE_URL=postgresql+psycopg://repoforge:repoforge-change-me@127.0.0.1:5432/repoforge
REPOFORGE_STORAGE_ROOT=/var/lib/repoforge
REPOFORGE_UPLOAD_ROOT=/var/lib/repoforge/uploads
REPOFORGE_WORKSPACE_ROOT=/var/lib/repoforge/workspaces
REPOFORGE_ARTIFACT_ROOT=/var/lib/repoforge/artifacts
REPOFORGE_KEY_ROOT=/var/lib/repoforge/keys
REPOFORGE_HOST=0.0.0.0
REPOFORGE_HTTP_PORT=80
REPOFORGE_HTTPS_PORT=443
REPOFORGE_TLS_CERT_FILE=/var/lib/repoforge/tls/repoforge.crt
REPOFORGE_TLS_KEY_FILE=/var/lib/repoforge/tls/repoforge.key
REPOFORGE_TLS_AUTO_GENERATE=1
REPOFORGE_TLS_SUBJECT_ALT_NAMES=localhost,127.0.0.1
REPOFORGE_TRUSTED_PROXY_IPS=127.0.0.1,::1
REPOFORGE_SECRET_KEY=change-me-before-production
REPOFORGE_AUTH_SECRET_KEY=change-me-before-production
